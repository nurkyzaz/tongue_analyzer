# Data & models (never commit large/clinical assets)
data/raw/
data/processed/
data/external/
*.zip
*.pt
*.pth
*.onnx
*.ckpt
checkpoints/
runs/
wandb/
mlruns/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
envs/
*.egg-info/
.ipynb_checkpoints/

# Secrets / local config
.env
*.key
secrets.yaml

# OS / editor
.DS_Store
.idea/
.vscode/

# demo example images (regenerated by scripts/build_examples.py from the dataset)
deployment/api/static/examples/*.jpg
deployment/api/static/examples/examples.json

# local test images (dataset samples; regenerate via scripts/make_test_set.py)
test_images/*.jpg

# TCM-Tongue (shezhen) dataset — large, kept out of git
shezhen datasets/
/tongue.zip
data/external/tcm_tongue/

# eval images (labels are tracked, raw images are not)
data/eval/**/*.jpg
data/eval/**/*.png
data/eval/**/*.jpeg

# self-contained labeling tool is a build artifact (2MB embedded images) — rebuild with build_label_tool.py
evaluation/label_*.html

# merged label store is a build artifact (needs server-side datasets to build)
data/processed/label_store.csv

# RAG corpus build artifacts (regenerate: build_corpus.py + rag.py --build)
stage2_interpretation/knowledge_base/corpus.jsonl
stage2_interpretation/knowledge_base/corpus_vecs.npy
stage2_interpretation/knowledge_base/corpus_meta.json

# labeled gallery reference (build artifact w/ embedded images)
evaluation/gallery.html

# human-label training artifacts (regenerate: build_human_manifest.py)
data/processed/human_manifest.csv
data/eval/human_masks/

# Licensed TCM literature (copyrighted books + source papers) — process locally, never commit
tongue_lit/

# compiled knowledge graph — rebuildable artifact (kg/build_kg.py); sources are tracked
stage2_interpretation/knowledge_base/kg_graph.json

# KG micro-layer QA artifacts (rebuildable; contain short book snippets — keep local)
stage2_interpretation/kg/kg_triplets_review.html
stage2_interpretation/knowledge_base/book_triplets.json
stage2_interpretation/knowledge_base/book_triplets_*.json

# reproducible eval outputs (numbers live in docs/PROGRESS.md)
evaluation/shadow_matcher_results.json
evaluation/faithfulness_results.json
